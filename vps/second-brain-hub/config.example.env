# second-brain-hub — config.example.env
# Copy to config.env locally or paste into Coolify → Environment Variables.

# === Google Drive (vault I/O) ===
# OBSIDIAN folder ID in user's Drive (Drive root for vault).
VAULT_DRIVE_ID=1YTTsTWFzrH6cNcZfvO_R-rhmSyFvlfz-

# OAuth user credentials (refresh token) for Drive API.
# Generate with: python3 scripts/oauth_setup.py
# Paste single-line JSON: cat ~/.config/mrluc/oauth_creds.json | jq -c .
GOOGLE_DRIVE_OAUTH_JSON={"installed":{"client_id":"...","client_secret":"...","refresh_token":"..."}}

# === Google Calendar (read-only events for dashboard) ===
# Service Account with Domain-Wide Delegation, subject = lukas@redbuttonedu.cz.
GOOGLE_DRIVE_SA_JSON={"type":"service_account","project_id":"..."}
CALENDAR_USER_EMAIL=lukas@redbuttonedu.cz
CALENDAR_DAYS_AHEAD=2

# === Misc ===
TZ=Europe/Prague

# === Local-only override (NOT used in Coolify) ===
# When running cron scripts on Mac without Drive API, point lib/drive_io.py at the
# local Drive Desktop mirror via VAULT_PATH. Cron container ignores this.
# VAULT_PATH=/Users/lukascypra/My Drive (lukas@redbuttonedu.cz)/SECOND_BRAIN/OBSIDIAN
