{
  "settings": {
    "migrated": 6,
    "iconPacksPath": ".obsidian/icons",
    "fontSize": 16,
    "emojiStyle": "native",
    "iconColor": null,
    "recentlyUsedIcons": [
      "LiLayoutDashboard",
      "LiPackage",
      "LiLandmark",
      "LiInbox",
      "LiFolders"
    ],
    "recentlyUsedIconsSize": 5,
    "rules": [
      {
        "rule": "02-PROJEKTY/finance.md",
        "icon": "LiLandmark",
        "for": "files",
        "order": 0,
        "useFilePath": true
      },
      {
        "rule": "^02-PROJEKTY/[^/]+\\.md$",
        "icon": "LiLayoutDashboard",
        "for": "files",
        "order": 1,
        "useFilePath": true
      },
      {
        "rule": "^02-PROJEKTY/finance$",
        "icon": "LiWallet",
        "for": "folders",
        "order": 2,
        "useFilePath": true
      },
      {
        "rule": "^02-PROJEKTY/[^/]+$",
        "icon": "LiPackage",
        "for": "folders",
        "order": 3,
        "useFilePath": true
      },
      {
        "rule": "^02-PROJEKTY/finance/.+",
        "icon": "LiFolderOpen",
        "for": "folders",
        "order": 4,
        "useFilePath": true
      }
    ],
    "extraMargin": {
      "top": 0,
      "right": 4,
      "bottom": 0,
      "left": 0
    },
    "iconInTabsEnabled": true,
    "iconInTitleEnabled": true,
    "iconInTitlePosition": "above",
    "iconInFrontmatterEnabled": false,
    "iconInFrontmatterFieldName": "icon",
    "iconColorInFrontmatterFieldName": "iconColor",
    "iconsBackgroundCheckEnabled": false,
    "iconsInNotesEnabled": true,
    "iconsInLinksEnabled": true,
    "iconIdentifier": ":",
    "lucideIconPackType": "native",
    "debugMode": false,
    "useInternalPlugins": false
  },
  "Home.md": "LiHouse",
  "00-System": "LiSettings",
  "01-INBOX": "LiInbox",
  "02-PROJEKTY": "LiFolders",
  "03-AREAS": "LiCompass",
  "05-RESOURCES": "LiLibrary",
  "06-Canvas": "LiLayout",
  "07-ARCHIV": "LiArchive"
}